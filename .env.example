## ================================================================
## Mushroom CP - Environment Variables Template
##
## HOW TO USE:
##   1. Copy this file: `cp .env.example .env`
##   2. Fill in strong passwords for all variables below.
##   3. NEVER commit the `.env` file to git (it is in .gitignore).
##
## SECURITY MODEL:
##   - All sensitive credentials live here, not in docker-compose.yml
##   - docker-compose.yml reads variables from this file at runtime
##
## DEVICE IDENTITY / PROVISIONING:
##   One firmware binary derives device_id from ESP32 STA MAC as mushroom_s3_<12 hex>.
##   A provisioning override may be stored in NVS. The device_id must equal
##   MQTT username, clientId, topic segment, and devices.device_id.
##   Each field device receives a unique PSK in NVS; firmware does not call
##   /auth/token on reconnect.
## ================================================================

# ----------------------------------------------------------------
# ----------------------------------------------------------------
# MQTT TCP Port (host-exposed)
# ----------------------------------------------------------------
MQTT_TCP_PORT=18883
# Firmware defaults, injected at PlatformIO build time.
MQTT_BROKER_URL=mushroomapp.mitelai.com
MQTT_PORT=1883

# ----------------------------------------------------------------
# Tenant namespace — governs all MQTT topics (${tenant}/...).
# Must match IOT_TENANT used by firmware and NestJS backend.
# ----------------------------------------------------------------
IOT_TENANT=mushroom

# ----------------------------------------------------------------
# MQTT Client Credentials: NestJS Backend
# Authentication via go-auth webhooks (x-www-form-urlencoded POST).
# ----------------------------------------------------------------
MQTT_BACKEND_USER=nestjs_backend
MQTT_BACKEND_PASS=CHANGE_ME_nestjs_strong_password_here

# ----------------------------------------------------------------
# Zero-touch MQTT bootstrap provisioning. The secret is injected into
# firmware only at build time and must never be committed.
# ----------------------------------------------------------------
MQTT_BOOTSTRAP_USER=provision_node
MQTT_BOOTSTRAP_SECRET=CHANGE_ME_a_long_random_bootstrap_secret
# House record that new unprovisioned devices are assigned to.
# This house MUST exist in the database before first provisioning.
DEFAULT_DEVICE_HOUSE_ID=house_01

# Browser-facing URL for mushroom-ui.
# Do not use Docker DNS name mushroom-backend in browser EventSource/fetch.
NEXT_PUBLIC_API_URL=http://localhost:6002

# ----------------------------------------------------------------
# PostgreSQL Database Credentials
# ----------------------------------------------------------------
POSTGRES_USER=mushroom_user
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password
POSTGRES_DB=mushroom_iot_db

# ----------------------------------------------------------------
# Application Ports
# ----------------------------------------------------------------
BE_HOST_PORT=6002
UI_HOST_PORT=6001

MQTT_BOOTSTRAP_SECRET=mush_temp_super_secret_2026

# ----------------------------------------------------------------
# Offline binary sync: NestJS subscribes to devices/+/sync_burst.
# In Docker Compose, use the internal broker hostname rather than localhost.
# ----------------------------------------------------------------
OFFLINE_SYNC_MQTT_URL=mqtt://mushroom-mqtt:1883
OFFLINE_SYNC_MQTT_USERNAME=nestjs_backend
OFFLINE_SYNC_MQTT_PASSWORD=CHANGE_ME_same_as_MQTT_BACKEND_PASS
OFFLINE_SYNC_MQTT_CLIENT_ID=mushroom_offline_sync

# ----------------------------------------------------------------
# InfluxDB v2: offline telemetry destination.
# INFLUXDB_TOKEN must be the same value as INFLUXDB_INIT_ADMIN_TOKEN for
# the compose-managed local instance. Use a separate write token in production.
# ----------------------------------------------------------------
INFLUXDB_URL=http://mushroom-influxdb:8086
INFLUXDB_ORG=mushroom
INFLUXDB_BUCKET=mushroom_iot
INFLUXDB_ANALYTICS_BUCKET=mushroom_analytics
INFLUXDB_TOKEN=CHANGE_ME_generate_a_long_random_influx_token
INFLUXDB_INIT_USERNAME=mushroom_admin
INFLUXDB_INIT_PASSWORD=CHANGE_ME_a_strong_influx_admin_password
