## ================================================================
## Mushroom CP - Environment Variables Template
##
## HOW TO USE:
##   1. Copy this file: `cp .env.example .env`
##   2. Fill in strong passwords for all variables below.
##   3. NEVER commit the `.env` file to git (it is in .gitignore).
##
## SECURITY MODEL:
##   - All sensitive credentials live here, not in docker-compose.yml
##   - docker-compose.yml reads variables from this file at runtime
##
## DEVICE IDENTITY / PROVISIONING:
##   One firmware binary derives device_id from ESP32 STA MAC as mushroom_s3_<12 hex>.
##   A provisioning override may be stored in NVS. The device_id must equal
##   MQTT username, clientId, EMQX topic segment, and devices.device_id.
##   Each field device receives a unique PSK in NVS; firmware does not call
##   /auth/token on reconnect.
## ================================================================

# ----------------------------------------------------------------
# EMQX Dashboard Admin Credentials
# Default: admin / public (MUST be changed for any real deployment)
# ----------------------------------------------------------------
EMQX_ADMIN_USER=admin
EMQX_ADMIN_PASS=admin_mushroom_2026_CHANGE_ME

# ----------------------------------------------------------------
# MQTT TCP Port (host-exposed)
# ----------------------------------------------------------------
MQTT_TCP_PORT=18883

# ----------------------------------------------------------------
# EMQX Dashboard Port (host-exposed)
# WARNING: Restrict this port in production firewall to admin IPs only.
# ----------------------------------------------------------------
EMQX_DASHBOARD_PORT=18083

# ----------------------------------------------------------------
# MQTT Client Credentials: NestJS Backend
# Permissions: Subscribe mushroom/#, Publish mushroom/device/+/setpoint
# ----------------------------------------------------------------
MQTT_BACKEND_USER=nestjs_backend
MQTT_BACKEND_PASS=CHANGE_ME_nestjs_strong_password_here

# ----------------------------------------------------------------
# Optional lab device credential seeded by docker init only.
# Production enrollment creates one EMQX user per MAC/NVS device_id.
# Golden rule: MQTT_ESP32_USER == firmware MQTT_CLIENT_ID_VAL == topic deviceId
# ----------------------------------------------------------------
MQTT_ESP32_USER=mushroom_s3_a1b2c3d4e5f6
MQTT_ESP32_PASS=CHANGE_ME_unique_device_psk_here

# Browser-facing URL and selected device for mushroom-ui.
# Do not use Docker DNS name mushroom-backend in browser EventSource/fetch.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_DEVICE_ID=mushroom_s3_a1b2c3d4e5f6

# ----------------------------------------------------------------
# PostgreSQL Database Credentials
# ----------------------------------------------------------------
POSTGRES_USER=mushroom_user
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password
POSTGRES_DB=mushroom_iot_db

# ----------------------------------------------------------------
# Application Ports
# ----------------------------------------------------------------
BE_HOST_PORT=6002
UI_HOST_PORT=6001
