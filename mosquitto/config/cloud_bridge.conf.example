# DietPi / Orange Pi Mosquitto bridge to the Mushroom cloud server.
#
# Install as: /etc/mosquitto/conf.d/cloud_bridge.conf
# Note: Replace 'mushroom_s3_a1b2c3d4e5f6' with your target ESP32 device_id.
# Note: Replace 'your_device_token_here' with the MQTT token assigned to that device.
# The cloud broker is exposed at mushroomapp.mitelai.com:10883. Its go-auth
# plugin communicates with mushroom-backend:3001 internally; DietPi does not.

connection cloud-mushroom-bridge
address mushroomapp.mitelai.com:10883

# Cloud identity: NestJS backend requires username == client ID == device ID.
remote_clientid mushroom_s3_a1b2c3d4e5f6
remote_username mushroom_s3_a1b2c3d4e5f6
remote_password b55f5baf-21d4-4ee4-b37f-05945a0f8464

# Send local device telemetry, status, tuning reports, and sync bursts to cloud.
topic mushroom/esp32/mushroom_s3_a1b2c3d4e5f6/up/# out 1
topic mushroom/esp32/mushroom_s3_a1b2c3d4e5f6/status out 1
topic devices/mushroom_s3_a1b2c3d4e5f6/sync_burst out 1

# Receive commands, acknowledgements, and dynamic tuning desired states from cloud.
topic mushroom/esp32/mushroom_s3_a1b2c3d4e5f6/down/# in 1

# Preserve the remote session and retry automatically after WAN interruptions.
cleansession false
notifications true
start_type automatic
restart_timeout 10

